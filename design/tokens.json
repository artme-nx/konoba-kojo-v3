{
  "$schema": "https://design-tokens.org/schema.json",
  "primitive": {
    "color": {
      "petrol": {
        "950": { "$value": "#0A141F", "$type": "color" },
        "900": { "$value": "#0F2030", "$type": "color" },
        "800": { "$value": "#182E42", "$type": "color" },
        "700": { "$value": "#264057", "$type": "color" }
      },
      "sand": {
        "100": { "$value": "#FBF4E8", "$type": "color" },
        "300": { "$value": "#E4D3B4", "$type": "color" },
        "500": { "$value": "#9C8E76", "$type": "color" }
      },
      "coral": {
        "400": { "$value": "#F0935C", "$type": "color" },
        "500": { "$value": "#E2703A", "$type": "color" },
        "700": { "$value": "#A84C24", "$type": "color" },
        "900": { "$value": "#4A2412", "$type": "color" }
      }
    },
    "font": {
      "display": { "$value": "var(--font-instrument), 'Instrument Serif', Georgia, serif", "$type": "fontFamily" },
      "sans": { "$value": "var(--font-inter), 'Inter', system-ui, sans-serif", "$type": "fontFamily" }
    },
    "motion": {
      "duration": {
        "micro": { "$value": "180ms", "$type": "duration" },
        "base": { "$value": "320ms", "$type": "duration" },
        "reveal": { "$value": "1.1s", "$type": "duration" },
        "cine": { "$value": "1.8s", "$type": "duration" }
      },
      "ease": {
        "out-expo": { "$value": "cubic-bezier(0.16, 1, 0.3, 1)", "$type": "cubicBezier" },
        "cine": { "$value": "cubic-bezier(0.65, 0, 0.35, 1)", "$type": "cubicBezier" }
      }
    },
    "tracking": {
      "display": { "$value": "-0.01em", "$type": "dimension" },
      "label": { "$value": "0.26em", "$type": "dimension" }
    }
  },
  "semantic": {
    "background": { "$value": "{primitive.color.petrol.950}", "$type": "color" },
    "foreground": { "$value": "{primitive.color.sand.100}", "$type": "color" },
    "card": { "$value": "{primitive.color.petrol.900}", "$type": "color" },
    "card-foreground": { "$value": "{primitive.color.sand.100}", "$type": "color" },
    "muted": { "$value": "{primitive.color.petrol.900}", "$type": "color" },
    "muted-foreground": { "$value": "{primitive.color.sand.500}", "$type": "color" },
    "accent": { "$value": "{primitive.color.petrol.800}", "$type": "color" },
    "accent-foreground": { "$value": "{primitive.color.sand.100}", "$type": "color" },
    "border": { "$value": "{primitive.color.petrol.700}", "$type": "color" },
    "ring": { "$value": "{primitive.color.coral.500}", "$type": "color" },
    "radius": { "$value": "1rem", "$type": "dimension" },
    "coral": { "$value": "{primitive.color.coral.500}", "$type": "color" },
    "coral-soft": { "$value": "{primitive.color.coral.400}", "$type": "color" },
    "coral-dim": { "$value": "{primitive.color.coral.900}", "$type": "color" },
    "surface-line": { "$value": "{primitive.color.petrol.700}", "$type": "color" },
    "type-display": { "$value": "{primitive.font.display}", "$type": "fontFamily" },
    "type-body": { "$value": "{primitive.font.sans}", "$type": "fontFamily" },
    "ease-reveal": { "$value": "{primitive.motion.ease.out-expo}", "$type": "cubicBezier" },
    "ease-cine": { "$value": "{primitive.motion.ease.cine}", "$type": "cubicBezier" },
    "duration-micro": { "$value": "{primitive.motion.duration.micro}", "$type": "duration" },
    "duration-base": { "$value": "{primitive.motion.duration.base}", "$type": "duration" },
    "duration-reveal": { "$value": "{primitive.motion.duration.reveal}", "$type": "duration" },
    "tracking-display": { "$value": "{primitive.tracking.display}", "$type": "dimension" },
    "tracking-label": { "$value": "{primitive.tracking.label}", "$type": "dimension" }
  },
  "component": {
    "hero": {
      "title-size": { "$value": "clamp(2.7rem, 7.2vw, 6rem)", "$type": "dimension" },
      "title-leading": { "$value": "1.03", "$type": "number" },
      "glow": {
        "$value": "radial-gradient(ellipse 70% 50% at 50% 100%, rgba(226, 112, 58, 0.24), rgba(74, 36, 18, 0.1) 45%, transparent 72%)",
        "$type": "gradient"
      },
      "vignette": {
        "$value": "linear-gradient(to top, rgba(10, 20, 31, 0.95) 0%, rgba(10, 20, 31, 0.28) 42%, rgba(10, 20, 31, 0.5) 100%)",
        "$type": "gradient"
      }
    },
    "button": {
      "primary-bg": { "$value": "{primitive.color.coral.500}", "$type": "color" },
      "primary-fg": { "$value": "{primitive.color.sand.100}", "$type": "color" },
      "primary-hover-bg": { "$value": "{primitive.color.coral.400}", "$type": "color" },
      "ghost-border": { "$value": "rgba(251, 244, 232, 0.32)", "$type": "color" },
      "ghost-hover-border": { "$value": "{primitive.color.coral.500}", "$type": "color" }
    }
  }
}
